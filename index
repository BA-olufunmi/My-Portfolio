            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background: #00d4ff;
            margin: 12px auto 0;
            border-radius: 9999px;
        }

        /* Better mobile typography */
        @media (max-width: 640px) {
            h1 {
                font-size: 2.5rem;
                line-height: 1.1;
