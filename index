    <!-- PROJECTS -->
    <section id="projects" class="py-16 sm:py-24 bg-slate-900">
        <div class="max-w-7xl mx-auto px-5 sm:px-6">
            <div class="text-center mb-12 sm:mb-16">
                <h2 class="heading text-4xl sm:text-5xl font-bold tracking-tighter section-header">Featured Projects</h2>
                <p class="text-slate-400 mt-4 text-base sm:text-lg">Real projects that delivered measurable business value</p>
            </div>
            
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
                <div onclick="showProject(1)" class="project-card bg-slate-800 rounded-3xl overflow-hidden cursor-pointer">
                    <img src="https://picsum.photos/id/1015/800/500" class="w-full h-52 sm:h-60 object-cover">
                    <div class="p-6 sm:p-8">
                        <h3 class="font-semibold text-xl sm:text-2xl mb-3">Enterprise Sales Performance Dashboard</h3>
                        <p class="text-slate-400 text-sm sm:text-base">Designed and implemented a real-time Power BI dashboard that improved forecast accuracy by 45% and reduced reporting time significantly.</p>
                        <div class="mt-6 text-xs uppercase tracking-widest text-cyan-400">Fintech • Power BI • SQL</div>
                    </div>
                </div>
                
                <div onclick="showProject(2)" class="project-card bg-slate-800 rounded-3xl overflow-hidden cursor-pointer">
                    <img src="https://picsum.photos/id/201/800/500" class="w-full h-52 sm:h-60 object-cover">
                    <div class="p-6 sm:p-8">
                        <h3 class="font-semibold text-xl sm:text-2xl mb-3">Supply Chain Process Optimization</h3>
                        <p class="text-slate-400 text-sm sm:text-base">Redesigned procurement and logistics workflows using process mining, resulting in 31% cost reduction and faster order fulfillment.</p>
                        <div class="mt-6 text-xs uppercase tracking-widest text-cyan-400">Retail • Lean Six Sigma • BPMN</div>
                    </div>
                </div>
                
                <div onclick="showProject(3)" class="project-card bg-slate-800 rounded-3xl overflow-hidden cursor-pointer">
                    <img src="https://picsum.photos/id/1005/800/500" class="w-full h-52 sm:h-60 object-cover">
                    <div class="p-6 sm:p-8">
                        <h3 class="font-semibold text-xl sm:text-2xl mb-3">Customer 360° Segmentation & Analytics</h3>
                        <p class="text-slate-400 text-sm sm:text-base">Built a predictive customer segmentation model that helped increase campaign ROI by 67% for a healthcare provider.</p>
                        <div class="mt-6 text-xs uppercase tracking-widest text-cyan-400">Healthcare • Python • Tableau</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="py-16 sm:py-24">
        <div class="max-w-7xl mx-auto px-5 sm:px-6">
            <div class="grid md:grid-cols-2 gap-12 md:gap-16">
                <div>
                    <h2 class="heading text-4xl sm:text-5xl font-bold tracking-tighter">Let's Create Impact Together</h2>
                    <p class="mt-6 text-slate-300 text-base sm:text-lg">
                        Whether you need business analysis support, a new dashboard, process improvement, or just want to discuss a project — I'm ready to help.
                    </p>
                    <div class="mt-12 space-y-6 text-base sm:text-lg">
                        <p>
                            <i class="fa-solid fa-envelope mr-4 text-cyan-400"></i> 
                            <a href="mailto:olufunmianimashaun2020@gmail.com" class="hover:text-cyan-400">olufunmianimashaun2020@gmail.com</a>
                        </p>
                        <p>
                            <i class="fa-brands fa-linkedin mr-4 text-cyan-400"></i> 
                            <a href="https://linkedin.com/in/oluwafunmilayo-animashaun" target="_blank" class="hover:text-cyan-400">linkedin.com/in/oluwafunmilayo-animashaun</a>
                        </p>
                        <p><i class="fa-solid fa-phone mr-4 text-cyan-400"></i> +234 801 234 5678</p>
                        <p><i class="fa-solid fa-location-dot mr-4 text-cyan-400"></i> Lagos, Nigeria</p>
                    </div>
                </div>
                
                <form onsubmit="handleForm(event)" class="space-y-6">
                    <input type="text" id="name" placeholder="Your Name" 
                           class="w-full bg-slate-800 border border-slate-700 rounded-3xl px-6 sm:px-7 py-5 sm:py-6 focus:border-cyan-400 outline-none text-base sm:text-lg">
                    <input type="email" id="email" placeholder="Your Email" 
                           class="w-full bg-slate-800 border border-slate-700 rounded-3xl px-6 sm:px-7 py-5 sm:py-6 focus:border-cyan-400 outline-none text-base sm:text-lg">
                    <textarea id="message" rows="5" placeholder="Tell me about your project or requirements..." 
                              class="w-full bg-slate-800 border border-slate-700 rounded-3xl px-6 sm:px-7 py-5 sm:py-6 focus:border-cyan-400 outline-none text-base sm:text-lg resize-none"></textarea>
                    <button type="submit" 
                            class="w-full bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-semibold py-6 sm:py-7 rounded-3xl text-lg sm:text-xl">
                        Send Message
                    </button>
                </form>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-black py-10 sm:py-12 text-center text-slate-500 text-sm">
        <p>© 2026 Oluwafunmilayo • Business Analyst</p>
        <p class="mt-2 text-xs sm:text-sm">Focused on delivering data-driven business solutions</p>
    </footer>

    <!-- PROJECT MODAL -->
    <div id="projectModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
        <div class="bg-slate-900 rounded-3xl max-w-2xl w-full p-6 sm:p-10">
            <div class="flex justify-end mb-6">
                <button onclick="closeModal()" class="text-4xl text-slate-400 hover:text-white">&times;</button>
            </div>
            <div id="modalContent" class="space-y-6"></div>
        </div>
    </div>

    <script>
        // Project Data
        const projects = {
            1: {
                title: "Enterprise Sales Performance Dashboard",
                tech: "Power BI • SQL • DAX • Azure",
                description: "Developed a comprehensive real-time dashboard for a leading fintech company. Consolidated data from CRM, ERP, and banking systems. The solution improved forecast accuracy by 45% and reduced monthly reporting time from 3 days to under 2 hours."
            },
            2: {
                title: "Supply Chain Process Optimization",
                tech: "Process Mining • Lean Six Sigma • BPMN",
                description: "Led end-to-end analysis and redesign of procurement and logistics processes for a major retail organization. Utilized process mining tools to identify bottlenecks, resulting in 31% cost reduction and 22% improvement in delivery speed."
            },
            3: {
                title: "Customer 360° Segmentation & Predictive Analytics",
                tech: "Python • Tableau • Machine Learning",
                description: "Built an advanced customer segmentation model using RFM analysis and clustering techniques. The project enabled highly targeted marketing campaigns and delivered a 67% increase in campaign ROI for a healthcare client."
            }
        };

        function showProject(id) {
            const modal = document.getElementById('projectModal');
            const content = document.getElementById('modalContent');
            
            content.innerHTML = `
                <h2 class="text-2xl sm:text-3xl font-bold mb-2">${projects[id].title}</h2>
                <p class="text-cyan-400 font-medium">${projects[id].tech}</p>
                <div class="h-px bg-slate-700 my-8"></div>
                <p class="text-slate-300 leading-relaxed">${projects[id].description}</p>
                
                <div class="mt-12 flex gap-4">
                    <button onclick="closeModal()" 
                            class="flex-1 py-4 sm:py-5 border border-slate-400 hover:border-slate-300 rounded-3xl text-base sm:text-lg">Close</button>
                    <button onclick="closeModal()" 
                            class="flex-1 py-4 sm:py-5 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-semibold rounded-3xl text-base sm:text-lg">View Full Case Study</button>
                </div>
            `;
            modal.classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('projectModal').classList.add('hidden');
        }

        // Form handler
        function handleForm(e) {
            e.preventDefault();
            alert("Thank you! Your message has been sent. I'll reply soon.");
            e.target.reset();
        }

        // Close modal when clicking outside
        document.getElementById('projectModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>
