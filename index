        <div class="max-w-7xl mx-auto px-5 sm:px-6">
            <h2 class="heading text-4xl sm:text-5xl font-bold text-center tracking-tighter mb-4 section-header">Skills & Tools</h2>
            <p class="text-center text-slate-400 mb-10 sm:mb-12 text-base sm:text-lg">What I use to deliver outstanding results</p>
            
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                <div class="bg-slate-900 p-6 sm:p-8 rounded-3xl hover:bg-slate-800 border border-transparent hover:border-cyan-400">
                    <i class="fa-solid fa-database text-4xl text-cyan-400 mb-4"></i>
                    <h4 class="font-semibold text-lg">Data Analysis</h4>
                    <p class="text-slate-400 text-sm sm:text-base">SQL • Python • Excel • Power Query</p>
                </div>
                <div class="bg-slate-900 p-6 sm:p-8 rounded-3xl hover:bg-slate-800 border border-transparent hover:border-cyan-400">
                    <i class="fa-solid fa-chart-pie text-4xl text-cyan-400 mb-4"></i>
                    <h4 class="font-semibold text-lg">Business Intelligence</h4>
                    <p class="text-slate-400 text-sm sm:text-base">Power BI • Tableau • Looker</p>
                </div>
                <div class="bg-slate-900 p-6 sm:p-8 rounded-3xl hover:bg-slate-800 border border-transparent hover:border-cyan-400">
                    <i class="fa-solid fa-diagram-project text-4xl text-cyan-400 mb-4"></i>
                    <h4 class="font-semibold text-lg">Requirements Engineering</h4>
                    <p class="text-slate-400 text-sm sm:text-base">BPMN • User Stories • Agile/Scrum</p>
                </div>
                <div class="bg-slate-900 p-6 sm:p-8 rounded-3xl hover:bg-slate-800 border border-transparent hover:border-cyan-400">
                    <i class="fa-solid fa-cloud text-4xl text-cyan-400 mb-4"></i>
