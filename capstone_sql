--viewing all tables data structure
SELECT * FROM aisle LIMIT 20;
SELECT * FROM departments LIMIT 20;
SELECT * FROM orders LIMIT 20;
SELECT * FROM products LIMIT 20;


-- Top 5 departments by total revenue
SELECT 
   d.department,
   ROUND(SUM(o.quantity * p.unit_price)::numeric, 2) AS total_revenue
FROM orders o
JOIN products p ON o.product_id = p.product_id
JOIN departments d ON p.department_id = d.department_id
GROUP BY d.department
ORDER BY total_revenue DESC;


-- Top 3 products by quantity sold on weekends
SELECT 
    p.product_name,
    d.department,
    SUM(o.quantity) AS total_quantity_sold
FROM orders o
JOIN products p ON o.product_id = p.product_id
JOIN departments d ON p.department_id = d.department_id
WHERE o.order_dow IN (0, 6)          -- weekend days
GROUP BY p.product_name, d.department
ORDER BY total_quantity_sold DESC;

--Does bread generate more profits than alcoholic products?
SELECT 
    CASE 
        WHEN d.department ILIKE '%bread%'          THEN 'Bread products'
        WHEN d.department ILIKE '%alcohol%' 
          OR d.department ILIKE '%alcoholic%' THEN 'Alcoholic products'
        ELSE 'Other'
    END AS category,
    ROUND(SUM(o.quantity * (p.unit_price - p.unit_cost))::numeric, 2) AS total_profit,
    ROUND(SUM(o.quantity * p.unit_price)::numeric, 2)                AS total_revenue,
    COUNT(*) AS number_of_order_lines
FROM orders o
JOIN products p ON o.product_id = p.product_id
JOIN departments d ON p.department_id = d.department_id
GROUP BY 
    CASE 
        WHEN d.department ILIKE '%bread%'          THEN 'Bread products'
        WHEN d.department ILIKE '%alcohol%' 
          OR d.department ILIKE '%alcoholic%' THEN 'Alcoholic products'
        ELSE 'Other'
    END
HAVING 
    CASE 
        WHEN d.department ILIKE '%bread%'          THEN 'Bread products'
        WHEN d.department ILIKE '%alcohol%' 
          OR d.department ILIKE '%alcoholic%' THEN 'Alcoholic products'
        ELSE 'Other'
    END IN ('Bread products', 'Alcoholic products')
ORDER BY total_profit DESC;

 --Which products have not been sold at all?
SELECT 
     p.product_id,
     p.product_name,
     d.department,
     p.unit_price
FROM products p
 LEFT JOIN orders o ON p.product_id = o.product_id
 JOIN departments d ON p.department_id = d.department_id
 WHERE o.product_id IS NULL
 ORDER BY p.product_name;
